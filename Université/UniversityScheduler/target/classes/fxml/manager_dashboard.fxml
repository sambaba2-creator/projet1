<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
             fx:controller="com.university.scheduler.ui.controller.ManagerDashboardController">
    
    <top>
        <VBox style="-fx-background-color: #2c3e50; -fx-padding: 10;">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Gestionnaire d'Emploi du Temps" 
                       style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold;"/>
                <Pane HBox.hgrow="ALWAYS"/>
                <Button text="Déconnexion" onAction="#handleLogout" 
                        style="-fx-font-size: 12; -fx-padding: 5 15;"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <TabPane fx:id="mainTabPane" tabClosingPolicy="UNAVAILABLE">
            
            <!-- Statistics Tab -->
            <Tab text="Statistiques">
                <VBox spacing="10" style="-fx-padding: 15;">
                    <Label text="Statistiques d'Utilisation" 
                           style="-fx-font-size: 16; -fx-font-weight: bold;"/>
                    
                    <GridPane hgap="20" vgap="20">
                        <VBox GridPane.columnIndex="0" GridPane.rowIndex="0" spacing="10"
                              style="-fx-border-color: #e74c3c; -fx-padding: 15; -fx-border-radius: 5;">
                            <Label text="Salles Critiques" style="-fx-font-size: 12;"/>
                            <Label fx:id="criticalRoomsLabel" text="0" 
                                   style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #e74c3c;"/>
                        </VBox>

                        <VBox GridPane.columnIndex="1" GridPane.rowIndex="0" spacing="10"
                              style="-fx-border-color: #3498db; -fx-padding: 15; -fx-border-radius: 5;">
                            <Label text="Salles Sous-utilisées" style="-fx-font-size: 12;"/>
                            <Label fx:id="underutilizedRoomsLabel" text="0" 
                                   style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #3498db;"/>
                        </VBox>
                    </GridPane>
                </VBox>
            </Tab>

            <!-- Courses Tab -->
            <Tab text="Cours">
                <VBox spacing="10" style="-fx-padding: 15;">
                    <Label text="Création de Cours" 
                           style="-fx-font-size: 16; -fx-font-weight: bold;"/>
                    
                    <HBox spacing="10">
                        <VBox spacing="5" prefWidth="250">
                            <Label text="Matière:" style="-fx-font-weight: bold;"/>
                            <TextField fx:id="courseSubjectField" promptText="Ex: Java"/>
                            
                            <Label text="Enseignant:" style="-fx-font-weight: bold;"/>
                            <ComboBox fx:id="courseTeacherCombo" prefWidth="250"/>
                            
                            <Label text="Classe:" style="-fx-font-weight: bold;"/>
                            <ComboBox fx:id="courseClassCombo" prefWidth="250"/>
                            
                            <Label text="Jour:" style="-fx-font-weight: bold;"/>
                            <ComboBox fx:id="courseDayCombo" prefWidth="250"/>
                            
                            <Label text="Heure de début:" style="-fx-font-weight: bold;"/>
                            <TextField fx:id="courseStartTimeField" promptText="14:30"/>
                            
                            <Label text="Durée (min):" style="-fx-font-weight: bold;"/>
                            <Spinner fx:id="courseDurationSpinner"/>
                            
                            <Label text="Salle:" style="-fx-font-weight: bold;"/>
                            <ComboBox fx:id="courseRoomCombo" prefWidth="250"/>
                            
                            <Button text="Créer Cours" onAction="#handleAddCourse" 
                                    style="-fx-padding: 8 15;"/>
                        </VBox>

                        <TableView fx:id="coursesTable" prefHeight="400">
                            <columns>
                                <TableColumn fx:id="courseSubjectCol" text="Matière" prefWidth="100"/>
                                <TableColumn fx:id="courseDayCol" text="Jour" prefWidth="100"/>
                                <TableColumn fx:id="courseTimeCol" text="Heure" prefWidth="150"/>
                            </columns>
                        </TableView>
                    </HBox>
                </VBox>
            </Tab>

            <!-- Room Search Tab -->
            <Tab text="Recherche de Salles">
                <VBox spacing="10" style="-fx-padding: 15;">
                    <Label text="Recherche de Salles Disponibles" 
                           style="-fx-font-size: 16; -fx-font-weight: bold;"/>
                    
                    <HBox spacing="10">
                        <VBox spacing="5" prefWidth="200">
                            <Label text="Capacité min:" style="-fx-font-weight: bold;"/>
                            <Spinner fx:id="searchCapacitySpinner"/>
                            
                            <Label text="Type:" style="-fx-font-weight: bold;"/>
                            <ComboBox fx:id="searchRoomTypeCombo" prefWidth="200"/>
                            
                            <Label text="Date:" style="-fx-font-weight: bold;"/>
                            <DatePicker fx:id="searchDatePicker"/>
                            
                            <Label text="Heure début:" style="-fx-font-weight: bold;"/>
                            <TextField fx:id="searchStartTimeField" promptText="14:30"/>
                            
                            <Label text="Heure fin:" style="-fx-font-weight: bold;"/>
                            <TextField fx:id="searchEndTimeField" promptText="16:30"/>
                            
                            <Button text="Rechercher" onAction="#handleSearchRooms" 
                                    style="-fx-padding: 8 15;"/>
                        </VBox>

                        <TableView fx:id="availableRoomsTable" prefHeight="400">
                            <columns>
                                <TableColumn fx:id="availRoomNumberCol" text="Numéro" prefWidth="100"/>
                                <TableColumn fx:id="availRoomCapacityCol" text="Capacité" prefWidth="100"/>
                            </columns>
                        </TableView>
                    </HBox>
                </VBox>
            </Tab>

            <!-- Schedule Management Tab -->
            <Tab text="Emploi du Temps">
                <VBox spacing="10" style="-fx-padding: 15;">
                    <Label text="Création d'Emploi du Temps" 
                           style="-fx-font-size: 16; -fx-font-weight: bold;"/>
                    
                    <HBox spacing="10">
                        <VBox spacing="5" prefWidth="280">
                            <Label text="Matière:" style="-fx-font-weight: bold;"/>
                            <TextField fx:id="scheduleSubjectField" promptText="Ex: Algorithmes"/>
                            
                            <Label text="Enseignant:" style="-fx-font-weight: bold;"/>
                            <ComboBox fx:id="scheduleTeacherCombo" prefWidth="280"/>
                            
                            <Label text="Classe:" style="-fx-font-weight: bold;"/>
                            <ComboBox fx:id="scheduleClassCombo" prefWidth="280"/>
                            
                            <Label text="Jour:" style="-fx-font-weight: bold;"/>
                            <ComboBox fx:id="scheduleDayCombo" prefWidth="280"/>
                            
                            <Label text="Heure de début:" style="-fx-font-weight: bold;"/>
                            <TextField fx:id="scheduleStartTimeField" promptText="14:30"/>
                            
                            <Label text="Durée (min):" style="-fx-font-weight: bold;"/>
                            <Spinner fx:id="scheduleDurationSpinner"/>
                            
                            <Label text="Salle:" style="-fx-font-weight: bold;"/>
                            <ComboBox fx:id="scheduleRoomCombo" prefWidth="280"/>
                            
                            <Button text="Ajouter à l'EDT" onAction="#handleAddSchedule" 
                                    style="-fx-padding: 10 15; -fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold;"/>
                        </VBox>

                        <TableView fx:id="scheduleTable" prefHeight="400">
                            <columns>
                                <TableColumn fx:id="scheduleSubjectCol" text="Matière" prefWidth="120"/>
                                <TableColumn fx:id="scheduleTeacherCol" text="Enseignant" prefWidth="140"/>
                                <TableColumn fx:id="scheduleClassCol" text="Classe" prefWidth="130"/>
                                <TableColumn fx:id="scheduleDayCol" text="Jour" prefWidth="110"/>
                                <TableColumn fx:id="scheduleTimeCol" text="Horaire" prefWidth="140"/>
                                <TableColumn fx:id="scheduleRoomCol" text="Salle" prefWidth="90"/>
                                <TableColumn fx:id="scheduleActionCol" text="Actions" prefWidth="100"/>
                            </columns>
                        </TableView>
                    </HBox>
                </VBox>
            </Tab>
        </TabPane>
    </center>
</BorderPane>
