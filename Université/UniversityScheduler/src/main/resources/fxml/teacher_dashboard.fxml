<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
             fx:controller="com.university.scheduler.ui.controller.TeacherDashboardController">
    
    <top>
        <VBox style="-fx-background-color: #2c3e50; -fx-padding: 10;">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Espace Enseignant" 
                       style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold;"/>
                <Pane HBox.hgrow="ALWAYS"/>
                <Button text="Déconnexion" onAction="#handleLogout" 
                        style="-fx-font-size: 12; -fx-padding: 5 15;"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <TabPane fx:id="mainTabPane" tabClosingPolicy="UNAVAILABLE">
            
            <!-- Schedule Tab -->
            <Tab text="Mon Emploi du Temps">
                <VBox spacing="10" style="-fx-padding: 15;">
                    <Label text="Votre Programme de Cours" 
                           style="-fx-font-size: 16; -fx-font-weight: bold;"/>
                    
                    <TableView fx:id="scheduleTable" prefHeight="400">
                        <columns>
                            <TableColumn fx:id="scheduleSubjectCol" text="Matière" prefWidth="120"/>
                            <TableColumn fx:id="scheduleDayCol" text="Jour" prefWidth="100"/>
                            <TableColumn fx:id="scheduleTimeCol" text="Horaire" prefWidth="120"/>
                            <TableColumn fx:id="scheduleRoomCol" text="Salle" prefWidth="80"/>
                        </columns>
                    </TableView>
                </VBox>
            </Tab>

            <!-- Room Reservation Tab -->
            <Tab text="Réserver une Salle">
                <VBox spacing="10" style="-fx-padding: 15;">
                    <Label text="Recherche et Réservation de Salles" 
                           style="-fx-font-size: 16; -fx-font-weight: bold;"/>
                    
                    <HBox spacing="10">
                        <VBox spacing="5" prefWidth="200">
                            <Label text="Capacité min:" style="-fx-font-weight: bold;"/>
                            <Spinner fx:id="searchCapacitySpinner"/>
                            
                            <Label text="Type de salle:" style="-fx-font-weight: bold;"/>
                            <ComboBox fx:id="searchRoomTypeCombo" prefWidth="200"/>
                            
                            <Label text="Date:" style="-fx-font-weight: bold;"/>
                            <DatePicker fx:id="searchDatePicker"/>
                            
                            <Label text="Heure début:" style="-fx-font-weight: bold;"/>
                            <TextField fx:id="searchStartTimeField" promptText="14:30"/>
                            
                            <Label text="Heure fin:" style="-fx-font-weight: bold;"/>
                            <TextField fx:id="searchEndTimeField" promptText="16:30"/>
                            
                            <Label text="Raison:" style="-fx-font-weight: bold;"/>
                            <TextArea fx:id="reasonTextArea" prefHeight="100" wrapText="true"/>
                            
                            <Button text="Rechercher" onAction="#handleSearchRooms" 
                                    style="-fx-padding: 8 15;"/>
                            <Button text="Réserver" onAction="#handleReserveRoom" 
                                    style="-fx-padding: 8 15; -fx-background-color: #2ecc71; -fx-text-fill: white;"/>
                        </VBox>

                        <TableView fx:id="availableRoomsTable" prefHeight="400">
                            <columns>
                                <TableColumn fx:id="availRoomNumberCol" text="Numéro" prefWidth="100"/>
                                <TableColumn fx:id="availRoomCapacityCol" text="Capacité" prefWidth="100"/>
                            </columns>
                        </TableView>
                    </HBox>
                </VBox>
            </Tab>

            <!-- Statistics Tab -->
            <Tab text="Mes Statistiques">
                <VBox spacing="10" style="-fx-padding: 15;">
                    <Label text="Statistiques d'Enseignement" 
                           style="-fx-font-size: 16; -fx-font-weight: bold;"/>
                    
                    <GridPane hgap="20" vgap="20">
                        <VBox GridPane.columnIndex="0" GridPane.rowIndex="0" spacing="10"
                              style="-fx-border-color: #3498db; -fx-padding: 15; -fx-border-radius: 5;">
                            <Label text="Nombre de Cours" style="-fx-font-size: 12;"/>
                            <Label fx:id="totalCoursesLabel" text="0" 
                                   style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #3498db;"/>
                        </VBox>

                        <VBox GridPane.columnIndex="1" GridPane.rowIndex="0" spacing="10"
                              style="-fx-border-color: #2ecc71; -fx-padding: 15; -fx-border-radius: 5;">
                            <Label text="Heures Totales" style="-fx-font-size: 12;"/>
                            <Label fx:id="totalHoursLabel" text="0" 
                                   style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #2ecc71;"/>
                        </VBox>
                    </GridPane>

                    <Label text="Rapport d'Emploi du Temps" 
                           style="-fx-font-size: 14; -fx-font-weight: bold;"/>
                    <Button text="Générer Rapport" onAction="#handleGenerateReport" 
                            style="-fx-padding: 8 15;"/>
                    <TextArea fx:id="reportTextArea" prefHeight="300" wrapText="true" editable="false"/>
                </VBox>
            </Tab>
        </TabPane>
    </center>
</BorderPane>

    -fx-border-radius: 3px;
}

/* DatePicker */
.date-picker {
    -fx-padding: 8px;
    -fx-font-size: 12px;
    -fx-border-color: #cccccc;
    -fx-border-radius: 3px;
}

/* TabPane */
.tab-pane {
    -fx-border-color: #ecf0f1;
}

.tab-pane .tab-header-background {
    -fx-background-color: #ecf0f1;
}

.tab {
    -fx-padding: 12px 30px;
    -fx-font-size: 12px;
}

.tab:selected {
    -fx-background-color: white;
}

.tab-label {
    -fx-font-weight: bold;
}

/* VBox and HBox */
.vbox {
    -fx-spacing: 10px;
}

.hbox {
    -fx-spacing: 10px;
}

/* Alert Dialog */
.alert {
    -fx-font-size: 12px;
}

.alert .header-panel {
    -fx-background-color: #3498db;
}

.alert .title {
    -fx-font-weight: bold;
    -fx-font-size: 14px;
}

/* Separator */
.separator {
    -fx-border-color: #bdc3c7;
}

/* Colors Usage */
.primary-color {
    -fx-text-fill: #3498db;
}

.success-color {
    -fx-text-fill: #2ecc71;
}

.warning-color {
    -fx-text-fill: #f39c12;
}

.error-color {
    -fx-text-fill: #e74c3c;
}

.info-color {
    -fx-text-fill: #3498db;
}

/* Header */
.header {
    -fx-background-color: #2c3e50;
    -fx-text-fill: white;
    -fx-padding: 10px;
    -fx-font-weight: bold;
}

/* Title */
.title {
    -fx-font-size: 18px;
    -fx-font-weight: bold;
    -fx-text-fill: #2c3e50;
}

.subtitle {
    -fx-font-size: 14px;
    -fx-font-weight: normal;
    -fx-text-fill: #7f8c8d;
}
