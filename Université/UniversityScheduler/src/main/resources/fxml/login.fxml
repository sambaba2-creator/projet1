<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
             fx:controller="com.university.scheduler.ui.controller.LoginController">
    <center>
        <VBox alignment="CENTER" spacing="20" style="-fx-background-color: #f5f5f5;">
            <padding>
                <Insets top="50" right="50" bottom="50" left="50"/>
            </padding>
            
            <!-- Title -->
            <VBox alignment="CENTER" spacing="10">
                <Text text="Université de thies" style="-fx-font-size: 36; -fx-font-weight: bold; -fx-fill: #2c3e50;"/>
                <Text text="Système de Gestion des Salles et Emplois du Temps" 
                      style="-fx-font-size: 14; -fx-fill: #7f8c8d;"/>
            </VBox>

            <!-- Login / Registration Form -->
            <VBox spacing="15" style="-fx-background-color: white; -fx-padding: 30; -fx-border-radius: 5; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                
                <!-- Email & Password Fields side-by-side -->
                <HBox spacing="20" alignment="CENTER">
                    <VBox spacing="5" maxWidth="280" HBox.hgrow="ALWAYS">
                        <Label text="Email:" style="-fx-font-size: 14; -fx-font-weight: bold;"/>
                        <TextField fx:id="emailField" 
                                   promptText="Entrez votre email"
                                   style="-fx-font-size: 12; -fx-padding: 10;"/>
                    </VBox>
                    <VBox spacing="5" maxWidth="280" HBox.hgrow="ALWAYS">
                        <Label text="Mot de passe:" style="-fx-font-size: 14; -fx-font-weight: bold;"/>
                        <StackPane>
                            <PasswordField fx:id="passwordField" 
                                           promptText="Entrez votre mot de passe"
                                           style="-fx-font-size: 12; -fx-padding: 10;"/>
                            <TextField fx:id="passwordVisibleField"
                                       promptText="Entrez votre mot de passe"
                                       style="-fx-font-size: 12; -fx-padding: 10;"
                                       visible="false" managed="false"/>
                        </StackPane>
                        <CheckBox fx:id="showPasswordCheck" text="Afficher"/>
                    </VBox>
                </HBox>

                <!-- Login Button -->
                <Button text="Connexion" 
                        onAction="#handleLogin"
                        style="-fx-font-size: 14; -fx-padding: 10 20; -fx-background-color: #3498db; -fx-text-fill: white; -fx-cursor: hand;"/>
            </VBox>
            
            <!-- Registration Form -->
            <VBox spacing="15" maxWidth="320" style="-fx-background-color: white; -fx-padding: 20; -fx-border-radius: 5; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                <Label text="Inscription" style="-fx-font-size: 16; -fx-font-weight: bold;"/>
                <HBox spacing="20" alignment="CENTER">
                    <VBox spacing="5" maxWidth="140" HBox.hgrow="ALWAYS">
                        <Label text="Nom:" style="-fx-font-size: 14; -fx-font-weight: bold;"/>
                        <TextField fx:id="regNameField" promptText="Nom complet"/>
                    </VBox>
                    <VBox spacing="5" maxWidth="140" HBox.hgrow="ALWAYS">
                        <Label text="Email:" style="-fx-font-size: 14; -fx-font-weight: bold;"/>
                        <TextField fx:id="regEmailField" promptText="Entrez votre email"/>
                    </VBox>
                </HBox>
                <HBox spacing="20" alignment="CENTER">
                    <VBox spacing="5" maxWidth="140" HBox.hgrow="ALWAYS">
                        <Label text="Mot de passe:" style="-fx-font-size: 14; -fx-font-weight: bold;"/>
                        <StackPane>
                            <PasswordField fx:id="regPasswordField" promptText="Entrez votre mot de passe"/>
                            <TextField fx:id="regPasswordVisibleField" promptText="Entrez votre mot de passe" visible="false" managed="false"/>
                        </StackPane>
                        <CheckBox fx:id="showRegPasswordCheck" text="Afficher"/>
                    </VBox>
                    <VBox spacing="5" maxWidth="140" HBox.hgrow="ALWAYS">
                        <Label text="Rôle:" style="-fx-font-size: 14; -fx-font-weight: bold;"/>
                        <ComboBox fx:id="regRoleCombo" promptText="Étudiant/Enseignant"/>
                    </VBox>
                </HBox>
                <Button text="S'inscrire" onAction="#handleRegister" 
                        style="-fx-font-size: 14; -fx-padding: 8 16; -fx-background-color: #27ae60; -fx-text-fill: white; -fx-cursor: hand;"/>
            </VBox>

            <!-- Info -->
            <VBox alignment="CENTER" spacing="5">
                <Text text="Identifiants de test:" 
                      style="-fx-font-size: 12; -fx-font-weight: bold; -fx-fill: #3498db;"/>
                <Text text="Admin: admin@university.edu / admin123" 
                      style="-fx-font-size: 11; -fx-fill: #7f8c8d;"/>
                <Text text="Manager: manager@university.edu / pass123" 
                      style="-fx-font-size: 11; -fx-fill: #7f8c8d;"/>
                <Text text="Teacher: ndiaye@university.edu / pass123" 
                      style="-fx-font-size: 11; -fx-fill: #7f8c8d;"/>
                <Text text="Student: student1@university.edu / pass123" 
                      style="-fx-font-size: 11; -fx-fill: #7f8c8d;"/>
            </VBox>
        </VBox>
    </center>
</BorderPane>
